# Copy this file to `.env` and fill in your own API keys.
# NOTE: Vite inlines any VITE_-prefixed variable into the client bundle,
# so these keys are visible to anyone using the deployed site. Use keys
# that are domain/referrer-restricted, or proxy requests through a backend
# to keep the real keys server-side.
VITE_BASESCAN_API_KEY=your_basescan_api_key_here
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here
